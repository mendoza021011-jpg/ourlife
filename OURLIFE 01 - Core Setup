/* =====================================================
 * LOCATION HELPER
 * ===================================================== */

if (!function_exists('ourlife_format_location')) {
    function ourlife_format_location($city = '', $province = '') {
        $parts = array_filter([
            sanitize_text_field($city),
            sanitize_text_field($province),
        ]);

        return implode(', ', $parts);
    }
}

/* =====================================================
 * NONCE HELPERS
 * ===================================================== */

if (!function_exists('ourlife_nonce_field')) {
    function ourlife_nonce_field($action = 'ourlife_action') {
        return wp_nonce_field($action, '_ourlife_nonce', true, false);
    }
}

if (!function_exists('ourlife_verify_nonce')) {
    function ourlife_verify_nonce($action = 'ourlife_action') {
        if (empty($_POST['_ourlife_nonce'])) {
            return false;
        }

        return wp_verify_nonce(sanitize_text_field(wp_unslash($_POST['_ourlife_nonce'])), $action);
    }
}

